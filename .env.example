# =============================================================================
# Quinn Awesome Skills Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control

# -----------------------------------------------------------------------------
# LLM Provider Configuration (for agent-powered skills)
# -----------------------------------------------------------------------------
# Supported providers: anthropic, infini
LLM_PROVIDER=infini

# -----------------------------------------------------------------------------
# Anthropic Configuration (provider=anthropic)
# -----------------------------------------------------------------------------
# Get your key at: https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# -----------------------------------------------------------------------------
# Infini GenStudio Configuration (provider=infini)
# -----------------------------------------------------------------------------
# Get your key at: https://cloud.infini-ai.com/genstudio/code
# API Key format: sk-cp-xxx
INFINI_API_KEY=sk-cp-your-api-key-here
INFINI_BASE_URL=https://cloud.infini-ai.com/maas/coding

# Default models (Claude Code compatible)
LLM_MODEL=glm-5
LLM_TEMPERATURE=0

# Model aliases for Claude Code compatibility
ANTHROPIC_DEFAULT_HAIKU_MODEL=glm-5
ANTHROPIC_DEFAULT_SONNET_MODEL=glm-5
ANTHROPIC_DEFAULT_OPUS_MODEL=glm-5

# -----------------------------------------------------------------------------
# Feishu/Lark API Configuration
# -----------------------------------------------------------------------------
# Required for: skills/url-fetcher/scripts/fetch_feishu.py
# Get credentials: https://open.feishu.cn/app
FEISHU_APP_ID=cli_xxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Required permissions:
# - docx:document:readonly (read documents)
# - wiki:wiki:readonly (read wiki pages)

# -----------------------------------------------------------------------------
# Web Search Configuration (Optional)
# -----------------------------------------------------------------------------
# Default: open-webSearch (no API key required)
# Run: npx open-websearch@latest

# Alternative: Jina AI Search API
# Get key: https://jina.ai/api-dashboard
# JINA_API_KEY=jina_xxxxxxxxxxxxx

# Alternative: Brave Search API
# Get key: https://api.search.brave.com
# BRAVE_SEARCH_API_KEY=BSAxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# Proxy Configuration (Optional)
# -----------------------------------------------------------------------------
# Uncomment if you need proxy for API calls
# USE_PROXY=true
# PROXY_URL=http://127.0.0.1:7890

# -----------------------------------------------------------------------------
# WeChat Playwright Configuration (Optional)
# -----------------------------------------------------------------------------
# Playwright browser path (for WeChat fetching)
# PLAYWRIGHT_BROWSERS_PATH=~/.cache/ms-playwright

# -----------------------------------------------------------------------------
# Application Configuration
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
